<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Annex-3: Vehicle Requisition Workflow</title>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
  
  <style>
    /* 
     * Vehicle Requisition Workflow System - Styling
     * Modern CSS including glassmorphic elements and print styles for A4 layout.
     */

    @import url('https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=Playfair+Display:ital,wght@0,600;1,600&display=swap');

    :root {
      /* Color system */
      --primary-hsl: 220, 85%, 57%;
      --primary: hsl(var(--primary-hsl));
      --primary-dark: hsl(220, 85%, 45%);
      --primary-light: hsl(220, 85%, 95%);
      --secondary: hsl(250, 70%, 55%);
      --accent: hsl(142, 70%, 45%);
      --accent-light: hsl(142, 70%, 95%);
      --danger: hsl(350, 80%, 55%);
      --danger-light: hsl(350, 80%, 95%);
      --warning: hsl(38, 92%, 50%);
      --warning-light: hsl(38, 92%, 95%);
      --info: hsl(190, 90%, 45%);
      --info-light: hsl(190, 90%, 95%);
      
      --text-main: hsl(210, 30%, 15%);
      --text-muted: hsl(210, 20%, 45%);
      
      --bg-main: hsl(210, 40%, 98%);
      --bg-card: hsl(0, 0%, 100%);
      
      --border-color: hsl(210, 20%, 90%);
      --radius-sm: 8px;
      --radius-md: 12px;
      --radius-lg: 20px;
      --shadow-sm: 0 2px 4px rgba(0,0,0,0.02);
      --shadow-md: 0 10px 25px -5px rgba(0,0,0,0.05), 0 8px 16px -8px rgba(0,0,0,0.05);
      --shadow-lg: 0 20px 40px -10px rgba(0,0,0,0.08);
      --transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

    /* Reset and Global Styles */
    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    body {
      font-family: 'Outfit', sans-serif;
      background-color: var(--bg-main);
      color: var(--text-main);
      line-height: 1.5;
      -webkit-font-smoothing: antialiased;
      min-height: 100vh;
    }

    /* Layout */
    .app-container {
      display: flex;
      flex-direction: column;
      min-height: 100vh;
    }

    header {
      background: rgba(255, 255, 255, 0.85);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--border-color);
      padding: 1rem 2rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
      position: sticky;
      top: 0;
      z-index: 100;
      box-shadow: var(--shadow-sm);
    }

    .brand {
      display: flex;
      align-items: center;
      gap: 0.75rem;
    }

    .brand-logo {
      width: 40px;
      height: 40px;
      background: linear-gradient(135deg, var(--primary), var(--secondary));
      border-radius: var(--radius-md);
      display: flex;
      align-items: center;
      justify-content: center;
      color: white;
      font-weight: 800;
      font-size: 1.25rem;
      box-shadow: 0 4px 10px rgba(var(--primary-hsl), 0.3);
    }

    .brand-text h1 {
      font-size: 1.25rem;
      font-weight: 700;
      letter-spacing: -0.5px;
      background: linear-gradient(135deg, var(--text-main), var(--primary-dark));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }

    .brand-text p {
      font-size: 0.75rem;
      color: var(--text-muted);
    }

    .user-controls {
      display: flex;
      align-items: center;
      gap: 1rem;
    }

    .role-badge {
      padding: 0.5rem 1rem;
      border-radius: 30px;
      font-size: 0.85rem;
      font-weight: 600;
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }

    .role-requester {
      background-color: var(--primary-light);
      color: var(--primary);
    }

    .role-officer {
      background-color: var(--accent-light);
      color: var(--accent);
    }

    .role-select-dropdown {
      padding: 0.4rem 0.8rem;
      border: 1px solid var(--border-color);
      border-radius: var(--radius-sm);
      background-color: white;
      font-family: inherit;
      font-weight: 500;
      font-size: 0.85rem;
      outline: none;
      cursor: pointer;
    }

    main {
      flex: 1;
      padding: 2rem;
      max-width: 1400px;
      width: 100%;
      margin: 0 auto;
    }

    .dashboard-grid {
      display: grid;
      grid-template-columns: 280px 1fr;
      gap: 2rem;
    }

    @media (max-width: 900px) {
      .dashboard-grid {
        grid-template-columns: 1fr;
      }
    }

    .dashboard-sidebar {
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    .dashboard-card {
      background: var(--bg-card);
      border-radius: var(--radius-lg);
      padding: 1.5rem;
      box-shadow: var(--shadow-md);
      border: 1px solid var(--border-color);
    }

    .sidebar-nav-btn {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      width: 100%;
      padding: 1rem;
      background: transparent;
      border: none;
      border-radius: var(--radius-md);
      text-align: left;
      font-family: inherit;
      font-size: 0.95rem;
      font-weight: 600;
      color: var(--text-muted);
      cursor: pointer;
      transition: var(--transition);
    }

    .sidebar-nav-btn.active {
      background: var(--primary-light);
      color: var(--primary);
    }

    .sidebar-nav-btn:hover:not(.active) {
      background: hsl(210, 20%, 95%);
      color: var(--text-main);
    }

    .stat-num {
      font-size: 2.25rem;
      font-weight: 700;
      line-height: 1;
      margin-top: 0.5rem;
    }

    .list-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 1.5rem;
    }

    .list-filters {
      display: flex;
      gap: 0.5rem;
      flex-wrap: wrap;
    }

    .filter-chip {
      padding: 0.4rem 1rem;
      border-radius: 30px;
      background: white;
      border: 1px solid var(--border-color);
      font-size: 0.85rem;
      font-weight: 500;
      cursor: pointer;
      transition: var(--transition);
    }

    .filter-chip.active {
      background: var(--text-main);
      color: white;
      border-color: var(--text-main);
    }

    .requests-table-container {
      overflow-x: auto;
      border-radius: var(--radius-md);
      border: 1px solid var(--border-color);
      background: white;
    }

    .requests-table {
      width: 100%;
      border-collapse: collapse;
      text-align: left;
    }

    .requests-table th {
      background: hsl(210, 20%, 97%);
      padding: 1rem;
      font-weight: 600;
      font-size: 0.85rem;
      color: var(--text-muted);
      border-bottom: 1px solid var(--border-color);
    }

    .requests-table td {
      padding: 1rem;
      border-bottom: 1px solid var(--border-color);
      font-size: 0.9rem;
    }

    .requests-table tbody tr {
      cursor: pointer;
      transition: var(--transition);
    }

    .requests-table tbody tr:hover {
      background-color: var(--primary-light);
    }

    .status-badge {
      display: inline-flex;
      align-items: center;
      gap: 0.35rem;
      padding: 0.25rem 0.75rem;
      border-radius: 30px;
      font-size: 0.75rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    .status-badge::before {
      content: '';
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: currentColor;
    }

    .status-pending {
      background-color: var(--warning-light);
      color: var(--warning);
    }

    .status-approved {
      background-color: var(--accent-light);
      color: var(--accent);
    }

    .status-rejected {
      background-color: var(--danger-light);
      color: var(--danger);
    }

    .status-returned {
      background-color: var(--info-light);
      color: var(--info);
    }

    .form-container {
      max-width: 800px;
      margin: 0 auto;
    }

    .form-card {
      background: white;
      border-radius: var(--radius-lg);
      padding: 2.5rem;
      box-shadow: var(--shadow-lg);
      border: 1px solid var(--border-color);
      margin-bottom: 2rem;
    }

    .form-title-block {
      text-align: center;
      margin-bottom: 2rem;
      border-bottom: 2px solid var(--border-color);
      padding-bottom: 1.5rem;
    }

    .form-title-block h2 {
      font-size: 1.75rem;
      font-weight: 800;
      color: var(--text-main);
    }

    .form-title-block p {
      color: var(--text-muted);
      font-size: 0.95rem;
      margin-top: 0.25rem;
    }

    .form-group-title {
      font-size: 1.1rem;
      font-weight: 700;
      color: var(--primary);
      margin-bottom: 1.25rem;
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }

    .form-group-title::after {
      content: '';
      flex: 1;
      height: 1px;
      background: var(--border-color);
    }

    .form-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.25rem;
      margin-bottom: 2rem;
    }

    @media (max-width: 600px) {
      .form-grid {
        grid-template-columns: 1fr;
      }
    }

    .form-col-span-2 {
      grid-column: span 2;
    }

    @media (max-width: 600px) {
      .form-col-span-2 {
        grid-column: span 1;
      }
    }

    .form-field {
      display: flex;
      flex-direction: column;
      gap: 0.4rem;
    }

    .form-field label {
      font-size: 0.85rem;
      font-weight: 600;
      color: var(--text-main);
    }

    .form-field input, .form-field select, .form-field textarea {
      padding: 0.8rem 1rem;
      border: 1px solid var(--border-color);
      border-radius: var(--radius-sm);
      font-family: inherit;
      font-size: 0.95rem;
      outline: none;
      background-color: hsl(210, 40%, 99%);
      transition: var(--transition);
    }

    .form-field input:focus, .form-field select:focus, .form-field textarea:focus {
      border-color: var(--primary);
      background-color: white;
      box-shadow: 0 0 0 3px rgba(var(--primary-hsl), 0.15);
    }

    .form-field input[readonly], .form-field select[disabled], .form-field textarea[readonly] {
      background-color: hsl(210, 20%, 95%);
      border-color: var(--border-color);
      color: var(--text-muted);
      cursor: not-allowed;
    }

    .vehicle-radio-group {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1rem;
      margin-top: 0.25rem;
    }

    .vehicle-radio-card {
      position: relative;
      border: 1px solid var(--border-color);
      border-radius: var(--radius-sm);
      padding: 0.75rem;
      text-align: center;
      cursor: pointer;
      font-weight: 600;
      font-size: 0.9rem;
      transition: var(--transition);
      background: white;
    }

    .vehicle-radio-card input {
      position: absolute;
      opacity: 0;
      cursor: pointer;
    }

    .vehicle-radio-card:hover {
      border-color: var(--primary);
      background: var(--primary-light);
    }

    .vehicle-radio-card.selected {
      border-color: var(--primary);
      background: var(--primary-light);
      color: var(--primary);
      box-shadow: 0 0 0 2px var(--primary);
    }

    /* Canvas Signature Area */
    .signature-box {
      border: 2px dashed var(--border-color);
      border-radius: var(--radius-md);
      padding: 1rem;
      background-color: hsl(210, 30%, 99%);
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.75rem;
    }

    .signature-canvas-wrapper {
      background: white;
      border: 1px solid var(--border-color);
      border-radius: var(--radius-sm);
      box-shadow: inset 0 2px 4px rgba(0,0,0,0.02);
      width: 100%;
      max-width: 500px;
      position: relative;
    }

    .signature-canvas {
      display: block;
      width: 100%;
      height: 180px;
      cursor: crosshair;
      background: transparent;
      touch-action: none;
    }

    .signature-controls {
      display: flex;
      gap: 0.5rem;
    }

    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 0.5rem;
      padding: 0.8rem 1.5rem;
      font-family: inherit;
      font-size: 0.95rem;
      font-weight: 600;
      border-radius: var(--radius-sm);
      cursor: pointer;
      transition: var(--transition);
      border: none;
      outline: none;
    }

    .btn-primary {
      background: linear-gradient(135deg, var(--primary), var(--secondary));
      color: white;
      box-shadow: 0 4px 15px rgba(var(--primary-hsl), 0.25);
    }

    .btn-primary:hover {
      transform: translateY(-1px);
      box-shadow: 0 6px 20px rgba(var(--primary-hsl), 0.35);
    }

    .btn-secondary {
      background-color: white;
      border: 1px solid var(--border-color);
      color: var(--text-main);
    }

    .btn-secondary:hover {
      background-color: hsl(210, 20%, 95%);
    }

    .btn-accent {
      background-color: var(--accent);
      color: white;
      box-shadow: 0 4px 10px rgba(142, 70, 45, 0.2);
    }

    .btn-accent:hover {
      background-color: hsl(142, 70%, 40%);
    }

    .btn-danger {
      background-color: var(--danger);
      color: white;
    }

    .btn-danger:hover {
      background-color: hsl(350, 80%, 45%);
    }

    .btn-warning {
      background-color: var(--warning);
      color: white;
    }

    .btn-warning:hover {
      background-color: hsl(38, 92%, 40%);
    }

    .btn-sm {
      padding: 0.4rem 0.8rem;
      font-size: 0.8rem;
    }

    .btn-group {
      display: flex;
      gap: 0.75rem;
      justify-content: flex-end;
      margin-top: 2rem;
    }

    .modal-overlay {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: rgba(15, 23, 42, 0.6);
      backdrop-filter: blur(4px);
      z-index: 1000;
      display: none;
      align-items: center;
      justify-content: center;
      padding: 1rem;
    }

    .modal-content {
      background: white;
      border-radius: var(--radius-lg);
      max-width: 500px;
      width: 100%;
      padding: 2rem;
      box-shadow: var(--shadow-lg);
      border: 1px solid var(--border-color);
      position: relative;
      animation: modalEnter 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
    }

    @keyframes modalEnter {
      from { transform: scale(0.95); opacity: 0; }
      to { transform: scale(1); opacity: 1; }
    }

    .modal-close {
      position: absolute;
      top: 1rem;
      right: 1rem;
      background: none;
      border: none;
      font-size: 1.5rem;
      cursor: pointer;
      color: var(--text-muted);
    }

    .alert-banner {
      padding: 1rem;
      border-radius: var(--radius-md);
      margin-bottom: 1.5rem;
      display: flex;
      align-items: flex-start;
      gap: 0.75rem;
      animation: slideDown 0.3s ease;
    }

    @keyframes slideDown {
      from { transform: translateY(-10px); opacity: 0; }
      to { transform: translateY(0); opacity: 1; }
    }

    .alert-success {
      background: var(--accent-light);
      color: hsl(142, 80%, 25%);
      border: 1px solid hsl(142, 40%, 80%);
    }

    .alert-danger {
      background: var(--danger-light);
      color: hsl(350, 80%, 25%);
      border: 1px solid hsl(350, 40%, 80%);
    }

    .alert-warning {
      background: var(--warning-light);
      color: hsl(38, 92%, 25%);
      border: 1px solid hsl(38, 40%, 80%);
    }

    .alert-info {
      background: var(--info-light);
      color: hsl(190, 90%, 25%);
      border: 1px solid hsl(190, 40%, 80%);
    }

    .spinner {
      width: 20px;
      height: 20px;
      border: 3px solid rgba(255,255,255,0.3);
      border-radius: 50%;
      border-top-color: white;
      animation: spin 0.8s linear infinite;
      display: inline-block;
    }

    @keyframes spin {
      to { transform: rotate(360deg); }
    }

    /* =========================================
       A4 PRINT STYLING & EXACT PDF FORM LAYOUT
       ========================================= */

    .a4-preview-container {
      display: flex;
      justify-content: center;
      margin-top: 2rem;
      margin-bottom: 2rem;
      overflow-x: auto;
    }

    .a4-page {
      width: 210mm;
      height: 297mm;
      padding: 15mm;
      background-color: white;
      color: black;
      box-sizing: border-box;
      font-family: 'Times New Roman', Times, serif;
      position: relative;
      border: 1px solid #c0c0c0;
      box-shadow: var(--shadow-lg);
      display: flex;
      flex-direction: column;
    }

    .a4-header {
      text-align: center;
      margin-bottom: 15px;
    }

    .a4-header h2 {
      font-size: 18px;
      font-weight: bold;
      text-transform: uppercase;
      margin-bottom: 5px;
      letter-spacing: 0.5px;
      font-family: 'Times New Roman', Times, serif;
    }

    .a4-meta-bar {
      display: flex;
      justify-content: space-between;
      font-size: 11px;
      font-weight: bold;
      margin-bottom: 10px;
      border-bottom: 1px solid black;
      padding-bottom: 3px;
    }

    .a4-section-title {
      font-size: 12px;
      font-weight: bold;
      margin-top: 10px;
      margin-bottom: 5px;
      text-transform: uppercase;
    }

    .a4-table {
      width: 100%;
      border-collapse: collapse;
      margin-bottom: 10px;
    }

    .a4-table th, .a4-table td {
      border: 1px solid black;
      padding: 5px 8px;
      font-size: 11px;
      font-family: 'Times New Roman', Times, serif;
      vertical-align: middle;
    }

    .a4-table th {
      background-color: #f2f2f2;
      font-weight: bold;
      text-transform: uppercase;
    }

    .a4-field-label {
      font-weight: bold;
      width: 30%;
      background-color: #fcfcfc;
    }

    .a4-field-value {
      width: 70%;
    }

    .a4-checkbox-group {
      display: flex;
      gap: 15px;
    }

    .a4-checkbox-item {
      display: flex;
      align-items: center;
      gap: 5px;
    }

    .a4-box {
      width: 12px;
      height: 12px;
      border: 1px solid black;
      display: inline-block;
      position: relative;
    }

    .a4-box.checked::after {
      content: '✓';
      position: absolute;
      top: -4px;
      left: 1px;
      font-size: 11px;
      font-weight: bold;
    }

    .a4-signatures-row {
      display: flex;
      justify-content: space-between;
      margin-top: 20px;
      margin-bottom: 15px;
      padding: 0 10px;
    }

    .a4-sig-col {
      width: 45%;
      display: flex;
      flex-direction: column;
      align-items: center;
    }

    .a4-sig-placeholder {
      border-bottom: 1px solid black;
      width: 100%;
      height: 45px;
      display: flex;
      justify-content: center;
      align-items: flex-end;
      position: relative;
    }

    .a4-sig-image {
      max-height: 40px;
      max-width: 120px;
      object-fit: contain;
      margin-bottom: 2px;
    }

    .a4-sig-label {
      font-size: 11px;
      font-weight: bold;
      margin-top: 5px;
      text-align: center;
    }

    .a4-notes {
      margin-top: auto; 
      border-top: 1px dashed black;
      padding-top: 10px;
      font-size: 10px;
      line-height: 1.3;
    }

    .a4-notes-title {
      font-weight: bold;
      margin-bottom: 4px;
    }

    .a4-notes ol {
      padding-left: 15px;
    }

    .a4-notes li {
      margin-bottom: 2px;
    }

    @media print {
      body {
        background: white;
        color: black;
      }
      
      .no-print {
        display: none !important;
      }
      
      .app-container {
        display: block;
        min-height: 0;
      }
      
      main {
        padding: 0;
        max-width: 100%;
        margin: 0;
      }
      
      .a4-preview-container {
        margin: 0;
        padding: 0;
        display: block;
        overflow-x: visible;
      }
      
      .a4-page {
        border: none;
        box-shadow: none;
        margin: 0;
        padding: 10mm;
        width: 210mm;
        height: 297mm;
        page-break-after: always;
        box-sizing: border-box;
      }
    }
  </style>
</head>
<body>
  <div class="app-container">
    <header class="no-print">
      <div class="brand">
        <div class="brand-logo">VR</div>
        <div class="brand-text">
          <h1>Vehicle Requisition System</h1>
          <p>Unico Hospitals - Official Workflow portal</p>
        </div>
      </div>
      
      <div style="display: flex; gap: 0.5rem; margin-left: 2rem; margin-right: auto;">
        <button class="sidebar-nav-btn active" id="nav-dashboard-btn" style="padding: 0.5rem 1rem; width: auto; font-size: 0.85rem;">Dashboard</button>
        <button class="sidebar-nav-btn" id="nav-new-request-btn" style="padding: 0.5rem 1rem; width: auto; font-size: 0.85rem;">New Request</button>
      </div>
      
      <div class="user-controls">
        <span style="font-size: 0.8rem; color: var(--text-muted); font-weight: 500;">Simulate Actor:</span>
        <select id="simulated-role" class="role-select-dropdown">
          <option value="Requester">Requester (Mahfuz)</option>
          <option value="Officer">Transport Officer (Rahim)</option>
          <option value="Admin">Department HOD (Admin)</option>
        </select>
        
        <div id="user-role-badge" class="role-badge role-requester">
          <span style="width: 8px; height: 8px; border-radius: 50%; background-color: currentColor;"></span>
          Mahfuz (Requester)
        </div>
      </div>
    </header>

