        return;
      }

      showLoader(true, 'Submitting requisition request...');

      const formData = {
        requesterNameId: document.getElementById('requesterNameId').value,
        designationDept: document.getElementById('designationDept').value,
        dateOfRequest: document.getElementById('dateOfRequest').value,
        dateOfTrip: document.getElementById('dateOfTrip').value,
        reportingTimePlace: document.getElementById('reportingTimePlace').value,
        destination: document.getElementById('destination').value,
        detailedPurpose: document.getElementById('detailedPurpose').value,
        noOfPassengers: document.getElementById('noOfPassengers').value,
        duration: document.getElementById('duration').value,
        vehicleType: document.querySelector('input[name="vehicleType"]:checked').value
      };

      const sigBase64 = state.requesterSigPad.getDataUrl();

      google.script.run
        .withSuccessHandler((response) => {
          showLoader(false);
          if (response.success) {
            showAlert('success', `Requisition form submitted successfully! Requisition ID: ${response.requestId}`);
            refreshRequestsList();
            navigateTo('dashboard');
          } else {
            showAlert('danger', 'Failed to submit request: ' + response.message);
          }
        })
        .withFailureHandler((error) => {
          showLoader(false);
          showAlert('danger', 'Server connection failure: ' + error.message);
        })
        .submitRequest(formData, sigBase64);
    }

    function handleRequestApproval(e) {
      e.preventDefault();

      const allottedVehicleNo = document.getElementById('det-allottedVehicleNo').value;
      const allottedDriver = document.getElementById('det-allottedDriver').value;
      const allottingPerson = document.getElementById('det-allottingPerson').value;
      const availEl = document.querySelector('input[name="det-vehicleAvailability"]:checked');

      if (!availEl) {
        showAlert('danger', 'Please confirm vehicle availability.');
        return;
      }

      const availability = availEl.value;

      if (availability === 'Available' && (!allottedVehicleNo || !allottedDriver || !allottingPerson)) {
        showAlert('danger', 'Please fill out vehicle registration, driver name, and approving person details.');
        return;
      }

      if (state.officerSigPad.isEmpty()) {
        showAlert('danger', 'Transport Officer signature is required for approval.');
        return;
      }

      showLoader(true, 'Approving requisition and compiling PDF...');

      const sectionBData = {
        vehicleAvailability: availability,
        allottedVehicleNo: allottedVehicleNo,
        allottedDriver: allottedDriver,
        allottingPerson: allottingPerson,
        hodSignatureBase64: state.hodSigPad.getDataUrl() 
      };

      const officerSigBase64 = state.officerSigPad.getDataUrl();
      const requestId = state.selectedRequest.RequestID;

      google.script.run
        .withSuccessHandler((response) => {
          if (response.success) {
            compileAndUploadPDF(requestId, () => {
              showLoader(false);
              showAlert('success', `Request ${requestId} approved and signed successfully. PDF generated.`);
              refreshRequestsList();
              navigateTo('dashboard');
            });
          } else {
            showLoader(false);
            showAlert('danger', 'Failed to approve request: ' + response.message);
          }
        })
        .withFailureHandler((error) => {
          showLoader(false);
          showAlert('danger', 'Server connection failure: ' + error.message);
        })
        .approveRequest(requestId, sectionBData, officerSigBase64);
    }

    function refreshRequestsList() {
      google.script.run
        .withSuccessHandler((requests) => {
          state.requests = requests;
          renderDashboardStats();
          renderRequestsTable();
          
          if (state.view === 'request-details' && state.selectedRequest) {
            loadRequestDetailView(state.selectedRequest.RequestID);
          }
        })
        .withFailureHandler((error) => {
          showAlert('danger', 'Failed to fetch database records: ' + error.message);
        })
        .getRequests();
    }

    function showRejectModal() {
      document.getElementById('reject-modal').style.display = 'flex';
    }

    function showReturnModal() {
      document.getElementById('return-modal').style.display = 'flex';
    }

    function hideModals() {
      document.getElementById('reject-modal').style.display = 'none';
      document.getElementById('return-modal').style.display = 'none';
      document.getElementById('reject-reason-input').value = '';
      document.getElementById('return-reason-input').value = '';
    }

    function handleRequestReject() {
      const reason = document.getElementById('reject-reason-input').value;
      if (!reason.trim()) {
        showAlert('warning', 'Please enter a reason for rejection.');
        return;
      }

      showLoader(true, 'Updating request status to Rejected...');
      const requestId = state.selectedRequest.RequestID;

      google.script.run
        .withSuccessHandler((response) => {
          showLoader(false);
          if (response.success) {
            showAlert('success', `Request ${requestId} rejected.`);
            refreshRequestsList();
            navigateTo('dashboard');
          }
        })
        .withFailureHandler((error) => {
          showLoader(false);
          showAlert('danger', 'Server connection error: ' + error.message);
        })
        .rejectRequest(requestId, reason);
    }

    function handleRequestReturn() {
      const reason = document.getElementById('return-reason-input').value;
      if (!reason.trim()) {
        showAlert('warning', 'Please enter a reason for returning the form.');
        return;
      }

      showLoader(true, 'Returning form for correction...');
      const requestId = state.selectedRequest.RequestID;

      google.script.run
        .withSuccessHandler((response) => {
          showLoader(false);
          if (response.success) {
            showAlert('success', `Request ${requestId} returned to requester for correction.`);
            refreshRequestsList();
            navigateTo('dashboard');
          }
        })
        .withFailureHandler((error) => {
          showLoader(false);
          showAlert('danger', 'Server connection error: ' + error.message);
        })
        .returnForCorrection(requestId, reason);
    }

    function compileAndUploadPDF(requestId, callback) {
      renderA4PrintTemplate(requestId);

      const element = document.getElementById('a4-print-template-node');
      
      const opt = {
        margin: 0,
        filename: `${requestId}_Requisition_Form.pdf`,
        image: { type: 'jpeg', quality: 0.98 },
        html2canvas: { scale: 2, useCORS: true },
        jsPDF: { unit: 'mm', format: 'a4', orientation: 'portrait' }
      };

      html2pdf().from(element).set(opt).outputPdf('datauristring').then(function(pdfBase64) {
        google.script.run
          .withSuccessHandler((response) => {
            if (callback) callback();
          })
          .withFailureHandler((error) => {
            console.error('PDF Upload Error:', error);
            showAlert('warning', 'Requisition was approved but PDF failed to mock upload: ' + error.message);
            if (callback) callback();
          })
          .saveGeneratedPDF(requestId, pdfBase64);
      });
    }

    function generateAndDownloadPDF(requestId) {
      renderA4PrintTemplate(requestId);
      const element = document.getElementById('a4-print-template-node');
      
      const opt = {
        margin: 0,
        filename: `${requestId}_Requisition_Form.pdf`,
        image: { type: 'jpeg', quality: 0.98 },
        html2canvas: { scale: 2, useCORS: true },
        jsPDF: { unit: 'mm', format: 'a4', orientation: 'portrait' }
      };

      html2pdf().from(element).set(opt).save();
    }

    function showLoader(show, text = 'Processing...') {
      const loader = document.getElementById('app-loader');
      document.getElementById('loader-text').innerText = text;
      loader.style.display = show ? 'flex' : 'none';
    }

    function showAlert(type, message) {
      const alertContainer = document.getElementById('alert-container');
      alertContainer.innerHTML = `
        <div class="alert-banner alert-${type}">
          <span><strong>${type === 'success' ? 'Success: ' : 'Alert: '}</strong>${message}</span>
          <button onclick="hideAlerts()" style="background:none; border:none; margin-left:auto; cursor:pointer; font-weight:700; color:inherit;">×</button>
        </div>
      `;
      alertContainer.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }

    function hideAlerts() {
      document.getElementById('alert-container').innerHTML = '';
    }

    function loadUserContext() {
      const select = document.getElementById('simulated-role');
      if (state.currentUser.role === 'Transport Officer') {
        select.value = 'Officer';
      } else if (state.currentUser.role === 'Department Admin') {
        select.value = 'Admin';
      } else {
        select.value = 'Requester';
      }
      updateRoleBadge();
    }

    function updateRoleBadge() {
      const badge = document.getElementById('user-role-badge');
      badge.className = 'role-badge';
      
      let roleClass = 'role-requester';
      if (state.currentUser.role === 'Transport Officer' || state.currentUser.role === 'Department Admin') {
        roleClass = 'role-officer';
      }
      
      badge.classList.add(roleClass);
      badge.innerHTML = `
        <span style="width: 8px; height: 8px; border-radius: 50%; background-color: currentColor;"></span>
        ${state.currentUser.name} (${state.currentUser.role})
      `;
    }
  </script>
</body>
</html>
